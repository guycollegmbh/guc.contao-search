<div class="guc-search" data-api="{{ apiUrl }}" data-min-chars="{{ minChars }}" data-debounce="{{ debounce }}" data-lang="{{ language }}">
    <div class="guc-search__field">
        <input
            type="search"
            class="guc-search__input"
            placeholder="{{ placeholder }}"
            autocomplete="off"
            aria-label="{{ placeholder }}"
        >
        <button class="guc-search__clear" aria-label="Suche leeren" hidden>✕</button>
    </div>
    <div class="guc-search__results" role="region" aria-live="polite" aria-label="Suchergebnisse" hidden></div>
</div>
